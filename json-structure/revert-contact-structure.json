{
  "title": "Revert Unified CRM Contact Structure",
  "description": "JSON structure documentation for the Revert normalized Contact entity",
  "type": "object",
  "fields": [
    { "name": "id", "type": "string", "required": true, "description": "Revert-normalized unique ID" },
    { "name": "remoteId", "type": "string", "required": false, "description": "Source CRM provider's native ID" },
    { "name": "firstName", "type": "string", "required": false, "description": "Contact first name" },
    { "name": "lastName", "type": "string", "required": false, "description": "Contact last name" },
    { "name": "email", "type": "string", "format": "email", "required": false, "description": "Primary email" },
    { "name": "phone", "type": "string", "required": false, "description": "Primary phone" },
    { "name": "company", "type": "string", "required": false, "description": "Employer/company name" },
    { "name": "title", "type": "string", "required": false, "description": "Job title" },
    { "name": "createdAt", "type": "string", "format": "date-time", "required": false },
    { "name": "updatedAt", "type": "string", "format": "date-time", "required": false },
    { "name": "additional", "type": "object", "required": false, "description": "Provider-specific non-unified fields" }
  ]
}
